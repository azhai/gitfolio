# Server Configuration
APP_MODE=debug
APP_THEME=orange
SERVER_PORT=9000
BASE_URL=http://127.0.0.1:9000

# Database Configuration
DB_TYPE=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
DB_NAME=./data/folio.db

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
SESSION_SECRET=your-session-secret-key
TOKEN_EXPIRY=24

# Admin Configuration
ADMIN_USERNAME=admin
ADMIN_PASSWORD="FolioAdmin"

# GitHub Configuration
GHITHUB_USERNAME=
GHITHUB_TOKEN=ghp_xxx

# Repository Storage
REPO_ROOT=./repos
